{
  "name": "@juggling-tools/server",
  "private": true,
  "version": "1.0.50",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "bun --env-file=../.env run --watch src/index.ts",
    "db:generate": "bun --env-file=../.env run drizzle-kit generate",
    "db:migrate": "bun --env-file=../.env run drizzle-kit migrate",
    "db:push": "bun --env-file=../.env run drizzle-kit push",
    "db:seed": "bun --env-file=../.env run scripts/seed.ts",
    "db:studio": "bun --env-file=../.env run drizzle-kit studio"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/openapi": "^1.4.14",
    "@sinclair/typebox": "^0.34.15",
    "better-auth": "^1.5.0",
    "drizzle-orm": "^0.45.1",
    "elysia": "1.4.27",
    "elysia-rate-limit": "^4.5.0",
    "postgres": "^3.4.8",
    "resend": "^6.9.3"
  },
  "devDependencies": {
    "bun-types": "1.3.10",
    "drizzle-kit": "^0.31.9"
  }
}
