:80 {
	handle /api/* {
		reverse_proxy server:3000
	}
	handle /openapi/* {
		reverse_proxy server:3000
	}
	handle /health {
		reverse_proxy server:3000
	}
	handle {
		root * /srv
		file_server
		try_files {path} /index.html

		@html path /index.html /
		header @html Cache-Control "no-cache, no-store, must-revalidate"

		@assets path /assets/*
		header @assets Cache-Control "public, max-age=31536000, immutable"
	}
}
