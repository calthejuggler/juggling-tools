  "onboarding_welcome_title": "Welcome to State Graphs",
  "onboarding_welcome_desc": "Ever wonder what patterns are possible with 3 balls? Or which tricks connect to each other? State graphs map out every possibility. In the next few steps, you'll see how.",
  "onboarding_state_title": "What is a State?",
  "onboarding_state_desc": "Imagine you're juggling 3 balls. Each beat you make one throw, and some balls are in the air while others are about to land. A state captures this moment: which future beats have a ball scheduled to land.",
  "onboarding_state_beat_explain": "Each column is a future beat. Filled = a ball is scheduled to land.",
  "onboarding_state_beat": "Beat {beat}",
  "onboarding_state_landing": "Ball landing",
  "onboarding_state_empty": "Empty beat",
  "onboarding_throws_title": "How Throws Work",
  "onboarding_throws_desc": "A throw sends a ball to a future beat. The throw height is how many beats ahead it will land. After each throw, time advances by one beat: every remaining ball shifts one beat closer to landing.",
  "onboarding_throws_quiz_prompt": "That throw of 4 changed the state. What would a throw of 3 from 00111 produce?",
  "onboarding_throws_quiz_check": "Check",
  "onboarding_throws_quiz_correct": "Correct! A throw of 3 lands right back where it came from, so the state doesn't change. This is the ground state's 'home throw'.",
  "onboarding_throws_quiz_wrong": "Not quite! A throw of 3 sends the ball exactly 3 beats ahead, which is where it started. The state stays the same!",
  "onboarding_throws_quiz_try_again": "Try again",
  "onboarding_throws_quiz_show_me": "Show me",
  "onboarding_throws_try_pattern": "Try a pattern",
  "onboarding_throws_play": "Play",
  "onboarding_throws_throwing": "Throwing a {height}...",
  "onboarding_throws_replay": "Replay",
  "onboarding_throws_throw_label": "Throw {height}",
  "onboarding_throws_pattern_label": "Pattern {pattern}",
  "onboarding_throws_pattern_441_desc": "Two high throws and a quick pass (3 balls)",
  "onboarding_throws_pattern_531_desc": "A high, a mid, and a handoff (3 balls)",
  "onboarding_throws_pattern_552_desc": "Two high throws and a hold (4 balls)",
  "onboarding_ground_title": "Ground & Excited States",
  "onboarding_ground_desc": "The ground state is the 'home base' - all balls land on consecutive beats. Excited states are everything else. Patterns can loop through excited states before returning to ground.",
  "onboarding_ground_label": "Ground state",
  "onboarding_excited_label": "Excited state",
