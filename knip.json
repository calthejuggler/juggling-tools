{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    ".": {
      "entry": ["scripts/*.ts"]
    },
    "web": {
      "entry": ["src/routes/**/*.{ts,tsx}"],
      "project": ["src/**/*.{ts,tsx}"],
      "ignore": ["src/components/ui/**"]
    },
    "server": {
      "entry": ["src/index.ts", "scripts/*.ts"],
      "project": ["src/**/*.ts", "scripts/**/*.ts"]
    },
    "packages/simulator/core": {
      "project": ["src/**/*.ts"]
    },
    "packages/simulator/react": {
      "project": ["src/**/*.{ts,tsx}"]
    }
  },
  "rules": {
    "duplicates": "off"
  }
}
